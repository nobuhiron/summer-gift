---
/**
 * セクションの背景画像を <Image>(object-fit:cover) で敷く部品。
 * CSS background だと sharp 最適化や loading="lazy" が効かないため、
 * 画面下方の cover 系背景はこの部品で <img> 化して webp＋遅延読込にする。
 *
 * 使い方: 親セクションに position:relative を付け、この部品を最初の子に置く。
 *         コンテンツ側は z-index:1 で前面に出す（.c-section-bg は z-index:0）。
 * 制約: タイル(repeat-y)やクロスフェード背景には使わない（CSS background のまま）。
 */
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src: ImageMetadata;
  /** object-position（元の background-position 相当） */
  position?: string;
  /** 画面上部の背景は 'eager'（LCPを遅らせないため）、下方は 'lazy' */
  loading?: 'lazy' | 'eager';
  class?: string;
}

const { src, position = 'top center', loading = 'lazy', class: className } = Astro.props;
---

<Image
  src={src}
  alt=""
  aria-hidden="true"
  loading={loading}
  decoding="async"
  class:list={['c-section-bg', className]}
  style={`object-position: ${position}`}
/>
