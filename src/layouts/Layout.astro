---
import '../styles/style.css';
import { FONT_LINKS, SITE } from '../config/site';
import PageChromeLeft from '../components/PageChromeLeft.astro';
import PageChromeRight from '../components/PageChromeRight.astro';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title = SITE.defaultTitle,
  description = SITE.defaultDescription,
  canonical,
  ogImage,
  noindex = false,
} = Astro.props;

const siteUrl = SITE.siteUrl ? new URL(SITE.siteUrl) : undefined;
const canonicalUrl = canonical
  ? siteUrl
    ? new URL(canonical, siteUrl).toString()
    : canonical
  : undefined;
const ogImageUrl = ogImage
  ? siteUrl
    ? new URL(ogImage, siteUrl).toString()
    : ogImage
  : SITE.defaultOgImage
    ? siteUrl
      ? new URL(SITE.defaultOgImage, siteUrl).toString()
      : SITE.defaultOgImage
    : undefined;
const robots = noindex ? 'noindex, nofollow' : 'index, follow';
const twitterCard = ogImageUrl ? 'summary_large_image' : 'summary';
---

<!doctype html>
<html lang={SITE.lang}>
  <head>
    <meta charset='utf-8' />
    <link rel='icon' type='image/svg+xml' href='/favicon.svg' />
    <meta name='viewport' content='width=device-width, initial-scale=1' />
    <meta name='generator' content={Astro.generator} />
    {FONT_LINKS.preconnect.map((href) => (
      <link rel='preconnect' href={href} crossorigin='anonymous' />
    ))}
    {FONT_LINKS.stylesheet && <link rel='stylesheet' href={FONT_LINKS.stylesheet} />}
    <meta name='description' content={description} />
    <meta name='robots' content={robots} />
    <meta property='og:type' content='website' />
    <meta property='og:site_name' content={SITE.siteName} />
    <meta property='og:locale' content={SITE.locale} />
    <meta property='og:title' content={title} />
    <meta property='og:description' content={description} />
    <meta name='twitter:card' content={twitterCard} />
    <meta name='twitter:title' content={title} />
    <meta name='twitter:description' content={description} />
    {canonicalUrl && <link rel='canonical' href={canonicalUrl} />}
    {canonicalUrl && <meta property='og:url' content={canonicalUrl} />}
    {ogImageUrl && <meta property='og:image' content={ogImageUrl} />}
    {ogImageUrl && <meta name='twitter:image' content={ogImageUrl} />}
    <title>{title}</title>
  </head>
  <body class='l-page'>
    <div class='l-page__bg' aria-hidden='true'></div>
    <div class='l-shell'>
      <aside class='l-shell__aside l-shell__aside--left'>
        <PageChromeLeft />
      </aside>
      <div class='l-shell__main'>
        <main id='main-content' class='l-main-column'>
          <slot />
        </main>
      </div>
      <aside class='l-shell__aside l-shell__aside--right'>
        <PageChromeRight />
      </aside>
    </div>
  </body>
</html>
