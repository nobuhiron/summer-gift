---
/**
 * 森半が選ばれている理由
 * 見出し＋理由カード（Swiper・矢印送り）。内容は父の日特集と共通の brandCards コレクション。
 */
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import { LINK_BASE } from '../data/links';
import { publicAssetPath } from '../utils/assets';
import treatmentReasons from '../assets/images/treatment-reasons.png';

const reasonEntries = await getCollection('brandCards');
const reasons = reasonEntries.map((entry) => ({
  eyebrow: entry.data.reason,
  title: entry.data.title,
  body: entry.data.description,
  image: entry.data.image,
  imageAlt: entry.data.imageAlt,
  cta: entry.data.cta,
  href: entry.data.ctaHref ?? entry.data.href ?? LINK_BASE,
}));
---

<section id="reason" class="l-section p-reason" aria-labelledby="heading-reason">
  <div class="l-container">
    <header class="p-reason__header">
      <h2 id="heading-reason" class="p-reason__title">森半が<br />選ばれている理由</h2>
      <Image src={treatmentReasons} alt="" aria-hidden="true" class="p-reason__wave" />
    </header>

    <div class="p-reason__carousel">
      <div class="swiper p-reason__swiper" data-carousel="slides" aria-label="森半が選ばれている理由">
        <ul class="swiper-wrapper" role="list">
        {reasons.map((reason) => (
          <li class="swiper-slide p-reason__item">
          <article class="c-reason-card">
            <img src={publicAssetPath('/logo.svg')} alt="" aria-hidden="true" class="c-reason-card__logo" />
            <p class="c-reason-card__eyebrow" aria-hidden="true">{reason.eyebrow}</p>
            <h3 class="c-reason-card__title">{reason.title}</h3>
            <Image src={reason.image} alt={reason.imageAlt} class="c-reason-card__image" />
            <p class="c-reason-card__body">{reason.body}</p>
            {reason.cta && (
              <a href={reason.href} class="c-reason-card__btn">
                <span>{reason.cta}</span>
              </a>
            )}
          </article>
          </li>
        ))}
      </ul>
      </div>
      <button class="p-reason__nav-btn p-reason__nav-btn--prev" aria-label="前へ" data-reason-prev></button>
      <button class="p-reason__nav-btn p-reason__nav-btn--next" aria-label="次へ" data-reason-next></button>
    </div>
  </div>
</section>
