---
/**
 * 価格帯で選ぶ
 */
import PriceBandCard from '../components/PriceBandCard.astro';
import { getCollection } from 'astro:content';
import { formatPriceBandLabel } from '../utils/text';
import { Image } from 'astro:assets';
import priceBg from '../assets/images/bg-wave-price.jpg';
import treatmentPrice from '../assets/images/treatment-price.png';
import price1000_1 from '../assets/images/price-1000-1.jpg';
import price2000_1 from '../assets/images/price-2000-1.jpg';
import price2000_2 from '../assets/images/price-2000-2.jpg';
import price2000_3 from '../assets/images/price-2000-3.jpg';
import price2000_4 from '../assets/images/price-2000-4.jpg';
import price2000_5 from '../assets/images/price-2000-5.jpg';
import price2000_6 from '../assets/images/price-2000-6.jpg';
import price2000_7 from '../assets/images/price-2000-7.jpg';
import price2000_8 from '../assets/images/price-2000-8.jpg';
import price4000_1 from '../assets/images/price-4000-1.jpg';
import price4000_2 from '../assets/images/price-4000-2.jpg';
import price4000_3 from '../assets/images/price-4000-3.jpg';
import price4000_4 from '../assets/images/price-4000-4.jpg';
import price4000_5 from '../assets/images/price-4000-5.jpg';
import price4000_6 from '../assets/images/price-4000-6.jpg';
import price6000_1 from '../assets/images/price-6000-1.jpg';
import price6000_2 from '../assets/images/price-6000-2.jpg';
import price6000_3 from '../assets/images/price-6000-3.jpg';

const pbEntries = await getCollection('priceBands');
const bands = pbEntries.map((e) => e.data);

const bandImages = {
  'band-1': [price1000_1],
  'band-2': [price2000_1, price2000_2, price2000_3, price2000_4, price2000_5, price2000_6, price2000_7, price2000_8],
  'band-3': [price4000_1, price4000_2, price4000_3, price4000_4, price4000_5, price4000_6],
  'band-4': [price6000_1, price6000_2, price6000_3],
} as const;
---

<section
  id="price"
  class="l-section l-section--bg-surface p-shop-by-price"
  aria-labelledby="heading-price"
  style={`--price-bg: url("${priceBg.src}")`}
>
  <!-- ヘッダー -->
  <div class="l-container">
    <header class="p-shop-by-price__header">
      <h2 id="heading-price" class="p-shop-by-price__heading">価格帯で選ぶ</h2>
      <Image src={treatmentPrice} alt="" aria-hidden="true" class="p-shop-by-price__wave" />
      <ul class="p-shop-by-price__tabs" role="list">
        {bands.map((band) => (
          <li>
            <a class="p-shop-by-price__tab" href={`#${band.id}`}>
              <span>{band.label}</span>
              <span class="p-shop-by-price__tab-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none"><path d="M9 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
              </span>
            </a>
          </li>
        ))}
      </ul>
    </header>

    <!-- 価格帯グループ -->
    <div class="p-shop-by-price__bands">
      {bands.map((band) => (
        <section id={band.id} class="p-shop-by-price__band" aria-labelledby={`heading-${band.id}`}>
          <header class="p-shop-by-price__band-header">
            <h3 id={`heading-${band.id}`} class="p-shop-by-price__band-title">
              {formatPriceBandLabel(band.label).map((part) => (
                part.className ? <span class={part.className}>{part.text}</span> : part.text
              ))}
              <br />
              <span class="p-shop-by-price__band-sub">おすすめアイテム</span>
            </h3>
          </header>
          <ul class="p-shop-by-price__list">
            {band.items.map((product, index) => (
              <li>
                <PriceBandCard
                  name={product.name}
                  price={product.price}
                  description={product.description}
                  href={product.href}
                  image={bandImages[band.id as keyof typeof bandImages][index]}
                />
              </li>
            ))}
          </ul>
        </section>
      ))}
    </div>
  </div>
</section>
