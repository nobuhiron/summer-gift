---
/**
 * 配送情報セクション
 */
import { publicAssetPath } from '../utils/assets';

const today = new Date();
const target = new Date(today.getFullYear(), 5, 21); // 6/21
if (target <= today) target.setFullYear(today.getFullYear() + 1);
const daysLeft = Math.min(99, Math.max(0, Math.ceil((target.getTime() - today.getTime()) / 86400000)));
const digitStr = String(daysLeft).padStart(2, '0');
const digitTens = digitStr[0];
const digitOnes = digitStr[1];
---

<section id="delivery" class="p-delivery-info" aria-labelledby="heading-delivery">
  <div class="l-container">
    <h2 id="heading-delivery" class="visually-hidden">配送情報</h2>
    <div class="p-delivery-info__inner">
      <div class="p-delivery-info__lead">
        {/* 年バッジ（2026 + 左右二重線） */}
        <div class="p-delivery-info__year-badge">
          <span class="p-delivery-info__year-line" aria-hidden="true"></span>
          <span class="p-delivery-info__year-text">2026</span>
          <span class="p-delivery-info__year-line" aria-hidden="true"></span>
        </div>

        <div class="p-delivery-info__date-group">
          {/* 父の日は 6月21日 */}
          <p class="p-delivery-info__date-line"><span class="p-delivery-info__date-prefix">父の日</span><span class="p-delivery-info__date-particle">は</span><span class="p-delivery-info__date-num">6</span><span class="p-delivery-info__date-unit">月</span><span class="p-delivery-info__date-num">21</span><span class="p-delivery-info__date-unit">日</span></p>

          {/* あと XX 日 */}
          <p class="p-delivery-info__countdown-line">
            <span class="p-delivery-info__count-text">あと</span>
            <span class="p-delivery-info__digits" data-fday-countdown aria-label={`あと${daysLeft}日`}>
              <span class="p-delivery-info__digit" data-fday-digit="tens">{digitTens}</span>
              <span class="p-delivery-info__digit" data-fday-digit="ones">{digitOnes}</span>
            </span>
            <span class="p-delivery-info__count-text">日</span>
          </p>
        </div>
      </div>

      {/* 配送案内 */}
      <div class="p-delivery-info__notice">
        <div class="p-delivery-info__notice-head">
          <img src={publicAssetPath('/delivery-arch.svg')} alt="" class="p-delivery-info__notice-arch" width="65" height="16" />
          <img src={publicAssetPath('/delivery-icon.svg')} alt="" class="p-delivery-info__notice-icon" width="46" height="38" />
        </div>
        <p class="p-delivery-info__tagline">
          <span class="p-delivery-info__tagline-black">父の日</span><span class="p-delivery-info__tagline-em">当日配達可能</span><span class="p-delivery-info__tagline-black">です</span>
        </p>
        <p class="p-delivery-info__deadline">
          <span class="p-delivery-info__deadline-num">6</span><span class="p-delivery-info__deadline-unit">月</span><span class="p-delivery-info__deadline-num">17</span><span class="p-delivery-info__deadline-unit">日</span><span class="p-delivery-info__deadline-unit">(水)</span><span class="p-delivery-info__deadline-time-em">正午</span><span class="p-delivery-info__deadline-num">12</span><span class="p-delivery-info__deadline-time-em">時</span><span class="p-delivery-info__deadline-until">までに</span><br /><span class="p-delivery-info__deadline-cta">ご注文ください。</span>
        </p>
      </div>

    </div>
  </div>
</section>

<script>
  // 父の日（6/21）までの残日数をクライアント側で毎日再計算する
  // ビルド時の値が dist に固定されてしまうのを防ぐため、表示時に上書きする
  const root = document.querySelector<HTMLElement>('[data-fday-countdown]');
  if (root) {
    const today = new Date();
    const target = new Date(today.getFullYear(), 5, 21); // 6/21
    if (target.getTime() <= today.getTime()) {
      target.setFullYear(today.getFullYear() + 1);
    }
    const days = Math.min(99, Math.max(0, Math.ceil((target.getTime() - today.getTime()) / 86400000)));
    const padded = String(days).padStart(2, '0');
    const tensEl = root.querySelector<HTMLElement>('[data-fday-digit="tens"]');
    const onesEl = root.querySelector<HTMLElement>('[data-fday-digit="ones"]');
    if (tensEl) tensEl.textContent = padded[0];
    if (onesEl) onesEl.textContent = padded[1];
    root.setAttribute('aria-label', `あと${days}日`);
  }
</script>
