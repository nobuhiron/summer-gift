---
/**
 * 森半の氷茶
 * 縦書き装飾タイトル＋茶碗写真のヒーロー → 導入文 → 商品カード（横スクロール）。
 * NOTE: koricha-hero.jpg は支給カンプ(森半の氷茶.jpg)からのスライス。商品画像はプレースホルダ。
 */
import { Image } from 'astro:assets';
import koriImage from '../assets/images/koricha-image.png';
import koriItem1 from '../assets/images/koricha-item-1.jpg';
import koriItem2 from '../assets/images/koricha-item-2.jpg';
import koriItem3 from '../assets/images/koricha-item-3.jpg';
import korichaBgSrc from '../assets/images/koricha-bg.jpg';
import { KORICHA_INTRO, KORICHA_PRODUCTS } from '../data/koricha-products';
import { splitLines } from '../utils/text';
import { publicAssetPath } from '../utils/assets';
import SectionBg from '../components/SectionBg.astro';

const koriItems = [koriItem1, koriItem2, koriItem3];

---

<section id="koricha" class="l-section p-koricha" aria-labelledby="heading-koricha">
  <SectionBg src={korichaBgSrc} position="top center" />
  <h2 id="heading-koricha" class="visually-hidden">森半の氷茶</h2>

  <div class="p-koricha__hero">
    <img src={publicAssetPath('/koricha-title.svg')} alt="" aria-hidden="true" class="p-koricha__hero-title" width="71" height="238" />
    <Image src={koriImage} alt="森半の氷茶（こおりちゃ）" class="p-koricha__hero-image" />
  </div>

  <div class="l-container">
    <div class="p-koricha__intro">
      {KORICHA_INTRO.map((para) => (
        <p class="p-koricha__intro-para">
          {splitLines(para).map((line, i, arr) => (
            <Fragment>{line}{i < arr.length - 1 && <br />}</Fragment>
          ))}
        </p>
      ))}
    </div>

    <div class="p-koricha__carousel">
      <div class="swiper p-koricha__swiper" data-carousel="free" data-scrollbar="#koricha-scrollbar" aria-label="氷茶 商品一覧">
        <ul class="swiper-wrapper" role="list">
          {KORICHA_PRODUCTS.map((product, i) => (
            <li class="swiper-slide p-koricha__item">
              <article class="c-koricha-card">
                <Image src={koriItems[i]} alt={`${product.name}の商品画像`} class="c-koricha-card__image" />
                <div class="c-koricha-card__body">
                  <h3 class="c-koricha-card__name">
                    {product.name}<span class="c-koricha-card__unit">{product.unit}</span>
                  </h3>
                  <p class="c-koricha-card__price">
                    <span class="c-koricha-card__price-yen">￥</span>{product.price}<span class="c-koricha-card__price-tax">(税込)</span>
                  </p>
                  <p class="c-koricha-card__desc">{product.description}</p>
                  <a href={product.href} class="c-koricha-card__btn">
                    <span class="c-koricha-card__btn-label">詳しくはこちら</span>
                    <span class="c-koricha-card__btn-icon" aria-hidden="true">
                      <svg viewBox="0 0 24 24" fill="none"><path d="M10 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
                    </span>
                  </a>
                </div>
              </article>
            </li>
          ))}
        </ul>
      </div>
      <div class="c-swiper-scrollbar-wrap" aria-hidden="true">
        <div id="koricha-scrollbar" class="swiper-scrollbar c-swiper-scrollbar"></div>
      </div>
    </div>
  </div>
</section>
