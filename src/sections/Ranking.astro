---
/**
 * お中元人気ランキング（ランキング.jpg / カード=1.png）
 * 王冠アイコン＋No.X の商品カードを Splide カルーセルで横並び。No.1〜3。
 * 王冠は支給 SVG（金/銀/銅）。商品画像は father のプレースホルダ（最終画像で差し替え）。
 * スクロールバーは後日追加予定。
 */
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import '@splidejs/splide/css/core';
import { splitLines } from '../utils/text';
import { publicAssetPath } from '../utils/assets';

const rankingItems = (await getCollection('ranking'))
  .map((entry) => entry.data)
  .sort((a, b) => a.rank - b.rank);

const crownByRank: Record<number, string> = {
  1: '/crown-icon.svg',
  2: '/crown-icon--silver.svg',
  3: '/crown-icon-bronze.svg',
};
const crownFor = (rank: number) => crownByRank[rank] ?? '/crown-icon.svg';

const rankColorByRank: Record<number, string> = {
  1: '#3d61b1',
  2: '#6c768a',
  3: '#b0936f',
};
const rankColorFor = (rank: number) => rankColorByRank[rank] ?? '#3d61b1';
---

<section id="ranking" class="l-section p-ranking" aria-labelledby="heading-ranking">
  <div class="l-container">
    <header class="p-ranking__header">
      <img src={publicAssetPath('/crown-icon.svg')} alt="" aria-hidden="true" class="p-ranking__header-crown" width="22" height="17" />
      <h2 id="heading-ranking" class="p-ranking__title">
        お中元<span class="p-ranking__title-accent">人気ランキング</span>
      </h2>
    </header>

    <div id="ranking-carousel" class="splide p-ranking__carousel" aria-label="お中元人気ランキング">
      <div class="splide__track">
        <ul class="splide__list">
          {rankingItems.map((item) => (
            <li class="splide__slide p-ranking__item">
              <p class="c-rank-card__badge">
                <img src={publicAssetPath(crownFor(item.rank))} alt="" aria-hidden="true" class="c-rank-card__crown" width="22" height="17" />
                <span class="c-rank-card__rank" style={`--rank-color: ${rankColorFor(item.rank)}`}>
                  <span class="c-rank-card__rank-label">No.</span><span class="c-rank-card__rank-num">{item.rank}</span>
                </span>
              </p>
              <a href={item.href} class="c-rank-card" aria-label={`${item.name.replace('\n', '')}の商品ページ`}>
                <div class="c-rank-card__image">
                  <Image src={item.image} alt={`${item.name.replace('\n', '')}の商品画像`} class="c-rank-card__image-el" />
                </div>
                <div class="c-rank-card__body">
                  <h3 class="c-rank-card__name">
                    {splitLines(item.name).map((line, index, lines) => (
                      <Fragment>
                        {line}
                        {index < lines.length - 1 && <br />}
                      </Fragment>
                    ))}
                  </h3>
                  <span class="c-rank-card__divider" aria-hidden="true"></span>
                  <p class="c-rank-card__price">
                    <span class="c-rank-card__price-yen">￥</span>{item.price}<span class="c-rank-card__price-tax">(税込)</span>
                  </p>
                </div>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>

<script is:inline src={publicAssetPath('/vendor/splide.min.js')} defer></script>
<script is:inline src={publicAssetPath('/scripts/ranking.js')} defer></script>
