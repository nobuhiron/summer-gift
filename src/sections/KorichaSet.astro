---
import { Image, getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import SectionBg from '../components/SectionBg.astro';
import {
  KORICHA_SET_DESC,
  KORICHA_ASSORTMENTS,
  KUZU_ASSORTMENTS,
  KUZU_GRID,
} from '../data/koricha-sets';
import assortment01 from '../assets/images/assortment-01.png';
import assortment02 from '../assets/images/assortment-02.png';
import assortment03 from '../assets/images/assortment-03.png';
import assortment04 from '../assets/images/assortment-04.png';
import assortment05 from '../assets/images/assortment-05.png';
import assortment06 from '../assets/images/assortment-06.png';
import assortment07 from '../assets/images/assortment-07.png';
import assortment08 from '../assets/images/assortment-08.png';
import assortment09 from '../assets/images/assortment-09.png';
import kuzusetBgSrc from '../assets/images/kuzuset-bg.png';
import treatmentKuzu from '../assets/images/treatment-kuzu.png';
import teaBgSrc from '../assets/images/koricha-set-bg.jpg';
import kuzuBlockBgSrc from '../assets/images/kuzu-bg.jpg';
import kuzuBannerBgSrc from '../assets/images/kuzu-bg-image.jpg';
import ribbonBgSrc from '../assets/images/koricha-ribon.jpg';

const kuzuGridImages = [assortment06, assortment07, assortment08, assortment09];
const kuzusetBg = await getImage({ src: kuzusetBgSrc });

const assortmentImages: Record<string, ImageMetadata> = {
  'Assortment 01': assortment01,
  'Assortment 02': assortment02,
  'Assortment 03': assortment03,
  'Assortment 04': assortment04,
  'Assortment 05': assortment05,
};
---

<section id="koricha-set" class="p-koricha-set" aria-labelledby="heading-koricha-set">
  <div class="p-koricha-set__block p-koricha-set__block--tea">
    <SectionBg src={teaBgSrc} position="top center" />
    <div class="l-container">
      <header class="p-koricha-set__heading">
        <h2 id="heading-koricha-set" class="p-koricha-set__heading-ja">氷茶<br />詰め合わせ</h2>
        <Image src={ribbonBgSrc} alt="" aria-hidden="true" class="p-koricha-set__heading-ribbon" />
      </header>

      <ul class="p-koricha-set__features" role="list">
        {KORICHA_ASSORTMENTS.map((item) => (
          <li class="c-assortment-card">
            <p class="c-assortment-card__no" aria-hidden="true">{item.no}</p>
            <h3 class="c-assortment-card__title">{item.title}</h3>
            {item.spec && <p class="c-assortment-card__spec">{item.spec}</p>}
            <p class="c-assortment-card__price">
              <span class="c-assortment-card__price-yen">￥</span>{item.price}<span class="c-assortment-card__price-tax">(税込)</span>
            </p>
            {assortmentImages[item.no] ? (
              <Image src={assortmentImages[item.no]} alt={`${item.title}の商品画像`} class="c-assortment-card__image" />
            ) : (
              <div class="c-assortment-card__image c-assortment-card__image--ph" role="img" aria-label={`${item.title}の商品画像`}></div>
            )}
            <p class="c-assortment-card__desc">{KORICHA_SET_DESC}</p>
            <a href={item.href} class="c-assortment-card__btn">
              <span>詳しくはこちら</span>
              <span class="c-assortment-card__btn-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none"><path d="M10 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
              </span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <div class="p-koricha-set__block p-koricha-set__block--kuzu">
    <SectionBg src={kuzuBlockBgSrc} position="bottom center" fit="contain" />
    <div class="p-koricha-set__heading-banner">
      <SectionBg src={kuzuBannerBgSrc} position="center" />
      <header class="p-koricha-set__heading">
        <h2 class="p-koricha-set__heading-ja">氷茶・くず餅<br />詰め合わせ</h2>
        <Image src={treatmentKuzu} alt="" aria-hidden="true" class="p-koricha-set__heading-dots" />
      </header>
    </div>

    <ul class="p-koricha-set__features" role="list">
      {KUZU_ASSORTMENTS.map((item) => (
        <li class="c-kuzuset-card">
          <img src={kuzusetBg.src} alt="" aria-hidden="true" loading="lazy" decoding="async" width={kuzusetBg.attributes.width} height={kuzusetBg.attributes.height} class="c-kuzuset-card__bg" />
          <div class="l-container c-kuzuset-card__inner">
            <Image src={assortmentImages[item.no]} alt={`${item.title}の商品画像`} class="c-kuzuset-card__image" />
            <p class="c-kuzuset-card__no" aria-hidden="true">{item.no}</p>
            <h3 class="c-kuzuset-card__title">
              {(() => {
                const idx = item.title.indexOf('(');
                if (idx === -1) return item.title;
                return (
                  <Fragment>
                    <span class="c-kuzuset-card__title-main">{item.title.slice(0, idx).trimEnd()}</span>
                    <span class="c-kuzuset-card__title-sub">{item.title.slice(idx)}</span>
                  </Fragment>
                );
              })()}
            </h3>
            <p class="c-kuzuset-card__price">
              <span class="c-kuzuset-card__price-yen">￥</span>{item.price}<span class="c-kuzuset-card__price-tax">(税込)</span>
            </p>
            <p class="c-kuzuset-card__desc">{KORICHA_SET_DESC}</p>
            <a href={item.href} class="c-kuzuset-card__btn">
              <span>詳しくはこちら</span>
              <span class="c-kuzuset-card__btn-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none"><path d="M10 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
              </span>
            </a>
          </div>
        </li>
      ))}
    </ul>

    <div class="l-container">
      <ul class="p-koricha-set__grid" role="list">
        {KUZU_GRID.map((item, i) => (
          <li class="c-kuzu-card">
            <Image src={kuzuGridImages[i]} alt={`${item.name}の商品画像`} class="c-kuzu-card__image" />
            <h3 class="c-kuzu-card__name">{item.name}</h3>
            <p class="c-kuzu-card__price">
              <span class="c-kuzu-card__price-yen">￥</span>{item.price}<span class="c-kuzu-card__price-tax">(税込)</span>
            </p>
            <a href={item.href} class="c-kuzu-card__btn">詳しくはこちら</a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
