---
/**
 * 森半の氷茶
 * 縦書き装飾タイトル＋茶碗写真のヒーロー → 導入文 → 商品カード（横スクロール）。
 * NOTE: hyocha-hero.jpg は支給カンプ(森半の氷茶.jpg)からのスライス。商品画像はプレースホルダ。
 */
import { Image } from 'astro:assets';
import koriImage from '../assets/images/koricha-image.png';
import { HYOCHA_INTRO, HYOCHA_PRODUCTS } from '../data/hyocha-products';
import { splitLines } from '../utils/text';
---

<section id="hyocha" class="l-section p-hyocha" aria-labelledby="heading-hyocha">
  <h2 id="heading-hyocha" class="visually-hidden">森半の氷茶</h2>

  <div class="p-hyocha__hero">
    <img src="/koricha-title.svg" alt="" aria-hidden="true" class="p-hyocha__hero-title" width="71" height="238" />
    <Image src={koriImage} alt="森半の氷茶（こおりちゃ）" class="p-hyocha__hero-image" />
  </div>

  <div class="l-container">
    <div class="p-hyocha__intro">
      {HYOCHA_INTRO.map((para) => (
        <p class="p-hyocha__intro-para">
          {splitLines(para).map((line, i, arr) => (
            <Fragment>{line}{i < arr.length - 1 && <br />}</Fragment>
          ))}
        </p>
      ))}
    </div>

    <div class="p-hyocha__carousel">
      <div class="swiper p-hyocha__swiper" data-carousel="free" data-scrollbar="#hyocha-scrollbar" aria-label="氷茶 商品一覧">
        <ul class="swiper-wrapper" role="list">
          {HYOCHA_PRODUCTS.map((product) => (
            <li class="swiper-slide p-hyocha__item">
              <article class="c-hyocha-card">
                <div class="c-hyocha-card__image" role="img" aria-label={`${product.name}の商品画像`}></div>
                <div class="c-hyocha-card__body">
                  <h3 class="c-hyocha-card__name">
                    {product.name}<span class="c-hyocha-card__unit">{product.unit}</span>
                  </h3>
                  <p class="c-hyocha-card__price">
                    <span class="c-hyocha-card__price-yen">￥</span>{product.price}<span class="c-hyocha-card__price-tax">(税込)</span>
                  </p>
                  <p class="c-hyocha-card__desc">{product.description}</p>
                  <a href={product.href} class="c-hyocha-card__btn">
                    <span class="c-hyocha-card__btn-label">詳しくはこちら</span>
                    <span class="c-hyocha-card__btn-icon" aria-hidden="true">
                      <svg viewBox="0 0 24 24" fill="none"><path d="M10 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
                    </span>
                  </a>
                </div>
              </article>
            </li>
          ))}
        </ul>
      </div>
      <div class="c-swiper-scrollbar-wrap" aria-hidden="true">
        <div id="hyocha-scrollbar" class="swiper-scrollbar c-swiper-scrollbar"></div>
      </div>
    </div>
  </div>
</section>
